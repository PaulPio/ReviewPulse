# ================================================================
# ReviewPulse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ================================================================

# ----------------------------------------------------------------
# Application
# ----------------------------------------------------------------
APP_NAME="ReviewPulse"
ENVIRONMENT=development         # development | staging | production
DEBUG=false

# ----------------------------------------------------------------
# Database (PostgreSQL + pgvector)
# Supabase free tier: get URL from Project Settings > Database
# Local dev: postgresql+asyncpg://postgres:postgres@localhost:5432/reviewpulse
# ----------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/reviewpulse

# ----------------------------------------------------------------
# Supabase Auth (optional)
# ----------------------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ----------------------------------------------------------------
# Redis / Celery
# Local dev: redis://localhost:6379/0
# Upstash Redis: rediss://default:password@host:6379
# ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ----------------------------------------------------------------
# Auth / Security
# Generate: openssl rand -hex 32
# ----------------------------------------------------------------
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# HMAC secret for webhook payload signing (N10)
WEBHOOK_HMAC_SECRET=change-me-webhook-hmac-secret

# ----------------------------------------------------------------
# Webhook target (N10)
# URL to POST ingestion.completed events to.
# Leave empty to disable webhook delivery.
# ----------------------------------------------------------------
WEBHOOK_TARGET_URL=

# ----------------------------------------------------------------
# LLM Providers (N2 - provider-agnostic with fallback)
# ----------------------------------------------------------------
LLM_PROVIDER=openrouter         # anthropic | openai | gemini | openrouter
LLM_FALLBACK_PROVIDER=          # leave blank or set a backup provider

# OpenRouter — unified gateway for 200+ models
# Get key: openrouter.ai/keys  Browse models: openrouter.ai/models
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001

# OpenAI — required for embeddings (text-embedding-3-small) regardless of LLM provider
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# Anthropic (only needed if LLM_PROVIDER=anthropic or as fallback)
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-1.5-flash

# ----------------------------------------------------------------
# LLM Retry policy (N5)
# ----------------------------------------------------------------
LLM_MAX_RETRIES=3
LLM_RETRY_MIN_WAIT=1.0
LLM_RETRY_MAX_WAIT=60.0

# ----------------------------------------------------------------
# Ingestion / Embeddings
# ----------------------------------------------------------------
SYNTHETIC_REVIEWS_PER_BOOK=50
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# ----------------------------------------------------------------
# Scheduled refresh (F9)
# Seconds between automatic re-ingestion runs per book
# ----------------------------------------------------------------
REFRESH_INTERVAL_SECONDS=3600

# ----------------------------------------------------------------
# CORS (comma-separated origins)
# ----------------------------------------------------------------
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ----------------------------------------------------------------
# Observability
# ----------------------------------------------------------------
LOG_LEVEL=INFO
SENTRY_DSN=
