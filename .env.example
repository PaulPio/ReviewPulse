# Database (local docker-compose)
DATABASE_URL=postgresql+psycopg://reviewpulse:reviewpulse@localhost:5433/reviewpulse

# Redis / Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# OpenRouter (https://openrouter.ai) — OpenAI-compatible API
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
OPENROUTER_APP_NAME=ReviewPulse
OPENROUTER_MODEL_ANALYSIS=openai/gpt-4o-mini
OPENROUTER_MODEL_EMBEDDING=openai/text-embedding-3-small
EMBEDDING_DIMENSIONS=1536

# Supabase Auth — JWT secret from Project Settings → API → JWT Secret (HS256)
SUPABASE_JWT_SECRET=
# When true, accept X-Dev-Author-Id header and skip JWT (local only)
DEV_AUTH_BYPASS=true

# Webhook (N10) — HMAC-SHA256 of raw body with this secret
WEBHOOK_SIGNING_SECRET=change-me-in-production
WEBHOOK_DELIVERY_URL=
# Optional: inbound POST /api/v1/webhooks/ingestion (defaults to WEBHOOK_SIGNING_SECRET if empty)
WEBHOOK_INGESTION_SECRET=

# Logging
LOG_LEVEL=INFO
